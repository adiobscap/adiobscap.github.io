# Normalize all text files to LF on commit, regardless of OS.
# This prevents Windows tools from re-introducing CRLF noise in diffs.
* text=auto eol=lf

# Source — explicit LF (defensive)
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf
*.py    text eol=lf
*.sh    text eol=lf  diff=bash

# Binaries — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.avif  binary
*.mp4   binary
*.mov   binary
*.webm  binary
*.mp3   binary
*.wav   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.gz    binary
